# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Feature Flags (Optional)
NEXT_PUBLIC_ENABLE_INTERVIEW=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Auth (Next API)
JWT_SECRET=please-change-me

# Supabase (replace with your project credentials)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-public-key

# AI Services (for interview system)
# Groq API (fast inference for LLaMA models)
GROQ_API_KEY=your-groq-api-key

# Alternative: OpenAI (for Whisper speech-to-text if needed)
OPENAI_API_KEY=your-openai-api-key-optional

# Text-to-Speech (you can use Web Speech API for free, or add a service)
# ELEVENLABS_API_KEY=your-elevenlabs-key-optional

