# ── Auth ──────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Generate one: openssl rand -hex 32
JWT_SECRET=please-change-me

# ── Supabase (Postgres + Storage) ────────────────────────────────────
# Hosted: project settings → API. Local dev: values printed by `npx supabase start`.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic Claude (AI screening, interviews, reports) ─────────────
# Without a key the app runs in deterministic "demo mode".
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ── Interview pipeline tuning (optional; defaults shown) ─────────────
# Round 1 pass threshold (%) used when a job doesn't set its own.
ROUND1_PASS_THRESHOLD=60
# Final score weights (%) — must sum to 100.
SCORE_WEIGHT_RESUME=20
SCORE_WEIGHT_ROUND1=35
SCORE_WEIGHT_ROUND2=45

# ── Email notifications (optional) ───────────────────────────────────
# If set, status emails are sent via Resend; otherwise they are logged.
# RESEND_API_KEY=re_...
# EMAIL_FROM=InterviewLytics <notifications@yourdomain.com>

# ── Frontend (optional) ──────────────────────────────────────────────
# Internal API routes are used by default; override only if hosting the API elsewhere.
# NEXT_PUBLIC_API_BASE_URL=/api
